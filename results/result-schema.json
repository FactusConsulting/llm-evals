{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Eval Result",
  "type": "object",
  "required": ["evaluator", "question_id", "section", "difficulty", "model_tested", "rating", "points", "max_points"],
  "properties": {
    "evaluator": {
      "type": "string",
      "description": "Model that performed the evaluation (e.g., claude-opus-4.6, gpt-5.4)"
    },
    "evaluator_version": {
      "type": "string",
      "description": "Specific version of the evaluator model"
    },
    "question_id": {
      "type": "string",
      "description": "Question identifier (e.g., N1, G7, K8)"
    },
    "section": {
      "type": "string",
      "description": "Category (e.g., Networking, Linux, Kubernetes, Go, Rust)"
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "model_tested": {
      "type": "string",
      "description": "Name of the model being evaluated"
    },
    "rating": {
      "type": "string",
      "enum": ["pass", "partial", "fail"]
    },
    "points": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "max_points": {
      "type": "integer",
      "const": 2
    },
    "key_points_correct": {
      "type": "array",
      "items": { "type": "string" }
    },
    "key_points_missing": {
      "type": "array",
      "items": { "type": "string" }
    },
    "key_points_wrong": {
      "type": "array",
      "items": { "type": "string" }
    },
    "brief_justification": {
      "type": "string"
    }
  }
}
